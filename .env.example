# LiteLLM model string — determines the provider automatically
MODEL_NAME=anthropic/claude-opus-4-6

# Provider API keys — only the key for your chosen provider is needed
ANTHROPIC_API_KEY=0

# --- Alternative providers (uncomment and set MODEL_NAME accordingly) ---
# MODEL_NAME=openai/gpt-4o
# OPENAI_API_KEY=

# MODEL_NAME=gemini/gemini-2.0-flash
# GEMINI_API_KEY=

# GitHub token for PR creation
GITHUB_TOKEN=0

# Phoenix collector endpoint for logging agent runs (optional, requires Phoenix setup)
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006

# Path to local mini-swe-agent config
MSWEA_MINI_CONFIG_PATH=mswea_config.yaml