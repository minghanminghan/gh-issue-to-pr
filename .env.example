MODEL_NAME=gemini/gemini-3.1-flash-lite
LOG_LEVEL=WARNING

#ANTHROPIC_API_KEY=0
# OPENAI_API_KEY=
GEMINI_API_KEY=0

# GitHub token for PR creation
GITHUB_TOKEN=0

# OTLP collector endpoint for tracing agent runs (optional, any OTLP-compatible collector)
OTEL_COLLECTOR_ENDPOINT=http://localhost:4318

# Path to local mini-swe-agent config
MSWEA_MINI_CONFIG_PATH=mswea_config.yaml